# Local Spring backend
PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:54330/poop_vibes
DATABASE_USERNAME=poop_vibes
DATABASE_PASSWORD=poop_vibes

# Local Next.js frontend
FRONTEND_PORT=3999
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional public host printed by the backend startup logger.
APP_PUBLIC_HOST=

# Optional local PWA/API knobs.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3999,http://localhost:3000,http://localhost:3001
APP_PUSH_PUBLIC_KEY=
APP_PUSH_PRIVATE_KEY=
APP_PUSH_SUBJECT=mailto:hello@poopvibe.local
APP_PUSH_TTL_SECONDS=3600
